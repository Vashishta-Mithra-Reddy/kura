# Copy to .env and fill in. Never commit the real .env.

# API credentials. Generate with: docker run --rm livekit/livekit-server generate-keys
# These EXACT values must also be set in the ekam deployment (LIVEKIT_API_KEY /
# LIVEKIT_API_SECRET) so the app and the server trust each other.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Public URL of the ekam web app's LiveKit webhook endpoint.
# Route lives at apps/web/src/app/api/voice/livekit/webhook/route.ts
LIVEKIT_WEBHOOK_URL=https://app.example.com/api/voice/livekit/webhook
