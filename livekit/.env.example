# Copy these into Dokploy's Environment tab. Never commit the real .env.

# API credentials. The EXACT same key/secret must be set in the ekam deployment
# (LIVEKIT_API_KEY / LIVEKIT_API_SECRET) so the app and server trust each other.
# Generate with: docker run --rm livekit/livekit-server generate-keys
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Full public URL of ekam's LiveKit webhook endpoint.
# Route lives at apps/web/src/app/api/voice/livekit/webhook/route.ts
LIVEKIT_WEBHOOK_URL=https://app.example.com/api/voice/livekit/webhook

# Optional: pin the server image. Defaults to livekit/livekit-server:latest.
# LIVEKIT_IMAGE=livekit/livekit-server:v1.8
